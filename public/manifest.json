{
  "manifest_version": 3,
  "name": "H Chat",
  "version": "1.0.0",
  "description": "AI 채팅 어시스턴트 · 메모리 · 스케줄러 · Agent Swarms",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "H Chat 열기",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "alarms",
    "sidePanel",
    "notifications",
    "activeTab",
    "scripting",
    "tabs",
    "tabGroups",
    "history"
  ],

  "host_permissions": [
    "https://bedrock-runtime.*.amazonaws.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/fab.js"],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "_execute_side_panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Open H Chat side panel"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
